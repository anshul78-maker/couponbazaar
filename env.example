# ============================================================
#  CouponBazaar — Environment Variables
#  1. Copy this file:  cp .env.example .env.local
#  2. Fill in your values below
#  3. NEVER commit .env.local to GitHub
# ============================================================

# ── Supabase (get from supabase.com → Project Settings → API) ──
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Razorpay (get from razorpay.com → Settings → API Keys) ────
VITE_RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXX

# ── Your deployed backend API URL (Railway / Render) ──────────
VITE_API_URL=https://your-backend.railway.app

# ── App Config ────────────────────────────────────────────────
VITE_APP_NAME=CouponBazaar
VITE_APP_URL=https://couponbazaar.vercel.app
